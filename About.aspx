<%@ Page Title="" Language="C#" MasterPageFile="~/Navigation.Master" AutoEventWireup="true" CodeBehind="About.aspx.cs" Inherits="Music_Studio_Booking.WebForm3" %>
<asp:Content ID="Content1" ContentPlaceHolderID="ContentPlaceHolder1" runat="server">
    <section class="page-hero">
    <div class="hero-content">
        <h1>About Us</h1>
        <p>Bringing your music to life</p>
    </div>
</section>

<section class="about-section">
    <div class="container">
        <div class="about-content">
            <h2>Our Story</h2>
            <p>G-Studio was created by students from Mapúa Malayan Colleges Laguna to help musicians and creators easily book rehearsal and recording spaces. As passionate musicians and tech enthusiasts ourselves, we recognized the challenges that student artists, bands, and content creators face when trying to find affordable, high-quality spaces for practice, recording, and production.</p>
            <p>Traditional studio booking can be complicated, expensive, and inaccessible for students. That's why we created G-Studio – a student-built platform designed to make studio booking simple, affordable, and accessible. Our goal is to empower the next generation of musicians and creators by providing them with the tools and spaces they need to bring their artistic visions to life.</p>

            <div class="mission-vision-grid">
                <div class="mission-section">
                    <h3>🎯 Our Mission</h3>
                    <ul>
                        <li>To provide an easy and efficient platform for booking music studio spaces.</li>
                        <li>To support students, musicians, and content creators with accessible rehearsal and recording facilities.</li>
                        <li>To encourage creativity, collaboration, and music production among young artists.</li>
                    </ul>
                </div>

                <div class="vision-section">
                    <h3>🔮 Our Vision</h3>
                    <ul>
                        <li>To become a trusted studio booking platform for students and musicians.</li>
                        <li>To build a creative community where artists can collaborate and grow.</li>
                        <li>To continuously improve studio access through technology and innovation.</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</section>
</asp:Content>
